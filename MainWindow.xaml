<Window x:Class="KanaoRemoveAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KANAO Remove AI  v1.0"
        Width="720" Height="880"
        MinWidth="620" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeepBrush}"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="CategoryHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" Padding="24,18">
            <Border.Effect>
                <DropShadowEffect Color="{StaticResource AccentCyan}" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,4">
                        <Run Text="⚡ "/>
                        <Run Text="KANAO" Foreground="{StaticResource AccentCyanBrush}"/>
                        <Run Text=" Remove AI"/>
                    </TextBlock>
                    <TextBlock Text="Advanced Windows AI Feature Manager — Disable, Remove &amp; Clean"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="v1.0.0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="AdminStatusText" Text="⚡ Administrator"
                               FontSize="11" Foreground="{StaticResource AccentGreenBrush}"
                               HorizontalAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ FEATURE CARDS ═══════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="20,0">
            <StackPanel x:Name="FeaturesPanel" Margin="0,8,0,8">

                <TextBlock Style="{StaticResource CategoryHeader}">
                    <Run Text="🛡️ " FontSize="14"/><Run Text="CORE AI REMOVAL"/>
                </TextBlock>
                <StackPanel x:Name="CoreAIPanel"/>

                <TextBlock Style="{StaticResource CategoryHeader}">
                    <Run Text="📦 " FontSize="14"/><Run Text="PACKAGE REMOVAL"/>
                </TextBlock>
                <StackPanel x:Name="PackagePanel"/>

                <TextBlock Style="{StaticResource CategoryHeader}">
                    <Run Text="🗑️ " FontSize="14"/><Run Text="DEEP CLEAN"/>
                </TextBlock>
                <StackPanel x:Name="DeepCleanPanel"/>

                <TextBlock Style="{StaticResource CategoryHeader}">
                    <Run Text="✏️ " FontSize="14"/><Run Text="APP SPECIFIC"/>
                </TextBlock>
                <StackPanel x:Name="AppSpecificPanel"/>

                <TextBlock Style="{StaticResource CategoryHeader}">
                    <Run Text="📁 " FontSize="14"/><Run Text="INSTALL CLASSIC APPS"/>
                </TextBlock>
                <StackPanel x:Name="ClassicAppsPanel"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════ MODE &amp; ACTIONS ═══════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderGlowBrush}" BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="Revert Mode" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <CheckBox x:Name="RevertModeToggle"
                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                  VerticalAlignment="Center"
                                  Checked="RevertModeToggle_Checked"
                                  Unchecked="RevertModeToggle_Unchecked"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Backup Mode" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <CheckBox x:Name="BackupModeToggle"
                                  Style="{StaticResource ToggleSwitchCheckBox}"
                                  VerticalAlignment="Center"
                                  Checked="BackupModeToggle_Checked"
                                  Unchecked="BackupModeToggle_Unchecked"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Select All" Style="{StaticResource GhostButton}"
                            Click="SelectAll_Click" Margin="0,0,8,0"/>
                    <Button Content="Deselect All" Style="{StaticResource GhostButton}"
                            Click="DeselectAll_Click" Margin="0,0,12,0"/>
                    <Button x:Name="ApplyButton" Content="⚡ Apply"
                            Style="{StaticResource PrimaryButton}"
                            Click="Apply_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ LOG PANEL ═══════════════ -->
        <Border Grid.Row="3" Background="#FF0A0A12"
                BorderBrush="{StaticResource BorderGlowBrush}" BorderThickness="0,1,0,0"
                MaxHeight="200">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF101018" Padding="16,8">
                    <Grid>
                        <TextBlock Text="📋 Output Log" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="StatusText" Text="Ready"
                                   HorizontalAlignment="Right"
                                   FontSize="11" Foreground="{StaticResource AccentCyanBrush}"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              MaxHeight="150" Padding="12,8">
                    <TextBlock x:Name="LogTextBlock"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Text="KANAO Remove AI — Ready"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════ FOOTER ═══════════════ -->
        <Border Grid.Row="4" Background="{StaticResource BgPanelBrush}"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    <Run Text="Developed by "/><Run Text="KANAO" Foreground="{StaticResource AccentCyanBrush}" FontWeight="SemiBold"/>
                    <Run Text="  •  v1.0.0  •  Windows 10/11"/>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💬 Discord" Style="{StaticResource GhostButton}"
                            Click="Discord_Click" Margin="0,0,8,0" FontSize="11" Padding="12,6"/>
                    <Button Content="🐙 GitHub" Style="{StaticResource GhostButton}"
                            Click="GitHub_Click" FontSize="11" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ OVERLAY ═══════════════ -->
        <Border x:Name="ProcessingOverlay" Grid.RowSpan="5"
                Background="#CC000008" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Width="64" Height="64" Margin="0,0,0,20">
                    <Ellipse Width="64" Height="64" Stroke="{StaticResource BorderGlowBrush}"
                             StrokeThickness="4"/>
                    <Ellipse x:Name="SpinnerArc" Width="64" Height="64"
                             Stroke="{StaticResource AccentCyanBrush}"
                             StrokeThickness="4"
                             StrokeDashArray="2,3"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation" Angle="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>

                <TextBlock x:Name="OverlayStatusText" Text="Processing..."
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="OverlayDetailText" Text="KANAO is working..."
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
